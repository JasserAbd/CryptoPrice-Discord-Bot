# Copy this file to ".env" and fill in your values.
# NEVER commit your real .env file or share your token.

# Required: your Discord bot token
# Get it from https://discord.com/developers/applications
#   -> your app -> Bot -> Reset Token -> Copy
DISCORD_TOKEN=paste_your_token_here

# Optional: command prefix for the old-style "!" commands (default: !)
COMMAND_PREFIX=!

# Optional: default exchange used for prices/charts (must be a CCXT id, e.g. binance, kraken, kucoin)
DEFAULT_EXCHANGE=binance

# Optional: default quote currency (e.g. USDT, USD)
DEFAULT_QUOTE=USDT

# Optional: CoinGecko API key (only if you have a paid/demo plan). Leave blank for free public API.
COINGECKO_API_KEY=
